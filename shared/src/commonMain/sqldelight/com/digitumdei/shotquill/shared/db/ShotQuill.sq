upsertPhotoEditRequest:
INSERT INTO photo_edit_requests(
  id,
  draft_id,
  source_media_asset_id,
  intent,
  realism_level,
  quality_tier,
  prompt,
  created_at_epoch_millis
) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(id) DO UPDATE SET
  draft_id = excluded.draft_id,
  source_media_asset_id = excluded.source_media_asset_id,
  intent = excluded.intent,
  realism_level = excluded.realism_level,
  quality_tier = excluded.quality_tier,
  prompt = excluded.prompt,
  created_at_epoch_millis = excluded.created_at_epoch_millis;

deletePhotoEditRequestsByDraftId:
DELETE FROM photo_edit_requests WHERE draft_id = ?;

selectPhotoEditRequestsByDraftId:
SELECT * FROM photo_edit_requests
WHERE draft_id = ?
ORDER BY created_at_epoch_millis ASC;

selectPhotoEditRequestById:
SELECT * FROM photo_edit_requests WHERE id = ?;

upsertPhotoEditResult:
INSERT INTO photo_edit_results(
  id,
  request_id,
  draft_id,
  edited_media_asset_id,
  summary,
  model_name,
  created_at_epoch_millis
) VALUES (?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(id) DO UPDATE SET
  request_id = excluded.request_id,
  draft_id = excluded.draft_id,
  edited_media_asset_id = excluded.edited_media_asset_id,
  summary = excluded.summary,
  model_name = excluded.model_name,
  created_at_epoch_millis = excluded.created_at_epoch_millis;

deletePhotoEditResultsByDraftId:
DELETE FROM photo_edit_results WHERE draft_id = ?;

selectPhotoEditResultsByDraftId:
SELECT photo_edit_results.*, media_assets.type, media_assets.uri, media_assets.mime_type,
       media_assets.width_px, media_assets.height_px, media_assets.created_at_epoch_millis AS media_created_at_epoch_millis
FROM photo_edit_results
JOIN media_assets ON media_assets.id = photo_edit_results.edited_media_asset_id
WHERE photo_edit_results.draft_id = ?
ORDER BY photo_edit_results.created_at_epoch_millis ASC;

selectPhotoEditResultById:
SELECT photo_edit_results.*, media_assets.type, media_assets.uri, media_assets.mime_type,
       media_assets.width_px, media_assets.height_px, media_assets.created_at_epoch_millis AS media_created_at_epoch_millis
FROM photo_edit_results
JOIN media_assets ON media_assets.id = photo_edit_results.edited_media_asset_id
WHERE photo_edit_results.id = ?;

