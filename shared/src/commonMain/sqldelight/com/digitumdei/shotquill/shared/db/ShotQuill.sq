deleteAllExportRecords:
DELETE FROM export_records;

deleteAllPromptHistoryEntries:
DELETE FROM prompt_history_entries;

deleteAllPhotoEditResults:
DELETE FROM photo_edit_results;

deleteAllPhotoEditRequests:
DELETE FROM photo_edit_requests;

deleteAllAltTextResults:
DELETE FROM alt_text_results;

deleteAllCaptionResultHashtags:
DELETE FROM caption_result_hashtags;

deleteAllCaptionResults:
