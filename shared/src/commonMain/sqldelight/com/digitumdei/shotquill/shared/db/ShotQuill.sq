selectPromptHistoryEntriesByDraftId:
SELECT * FROM prompt_history_entries
WHERE draft_id = ?
ORDER BY created_at_epoch_millis ASC;

selectPromptHistoryEntryById:
SELECT * FROM prompt_history_entries WHERE id = ?;

upsertExportRecord:
INSERT INTO export_records(
  id,
  draft_id,
  target_platform,
  status,
  destination_uri,
  error_message,
  created_at_epoch_millis,
  completed_at_epoch_millis
) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(id) DO UPDATE SET
  draft_id = excluded.draft_id,
  target_platform = excluded.target_platform,
  status = excluded.status,
  destination_uri = excluded.destination_uri,
  error_message = excluded.error_message,
  created_at_epoch_millis = excluded.created_at_epoch_millis,
  completed_at_epoch_millis = excluded.completed_at_epoch_millis;

deleteExportRecordsByDraftId:
DELETE FROM export_records WHERE draft_id = ?;

selectExportRecordsByDraftId:
SELECT * FROM export_records
WHERE draft_id = ?
ORDER BY created_at_epoch_millis ASC;

selectExportRecordById:
SELECT * FROM export_records WHERE id = ?;

deleteAllExportRecords:
DELETE FROM export_records;

deleteAllPromptHistoryEntries:
DELETE FROM prompt_history_entries;

deleteAllPhotoEditResults:
DELETE FROM photo_edit_results;

deleteAllPhotoEditRequests:
DELETE FROM photo_edit_requests;

deleteAllAltTextResults:
DELETE FROM alt_text_results;

deleteAllCaptionResultHashtags:
DELETE FROM caption_result_hashtags;

deleteAllCaptionResults:
DELETE FROM caption_results;

deleteAllCaptionRequests:
DELETE FROM caption_requests;

deleteAllVisionDescriptions:
DELETE FROM vision_descriptions;

deleteAllPostDraftCaptionHashtags:
DELETE FROM post_draft_caption_hashtags;

deleteAllPostDraftMediaItems:
DELETE FROM post_draft_media_items;

deleteAllPostDraftTargetPlatforms:
DELETE FROM post_draft_target_platforms;

deleteAllPostDrafts:
DELETE FROM post_drafts;

deleteAllBrandImageAssets:
DELETE FROM brand_image_assets;

deleteAllBrandProfileDefaultHashtags:
DELETE FROM brand_profile_default_hashtags;

deleteAllBrandProfiles:
DELETE FROM brand_profiles;

deleteAllMediaAssets:
DELETE FROM media_assets;
