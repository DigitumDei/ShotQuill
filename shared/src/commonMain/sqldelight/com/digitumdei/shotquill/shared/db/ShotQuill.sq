INSERT INTO prompt_history_entries(
  id,
  draft_id,
  operation_type,
  prompt,
  response_summary,
  model_name,
  created_at_epoch_millis
) VALUES (?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(id) DO UPDATE SET
