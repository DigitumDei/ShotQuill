deletePhotoEditResultsByDraftId:
DELETE FROM photo_edit_results WHERE draft_id = ?;

selectPhotoEditResultsByDraftId:
SELECT photo_edit_results.*, media_assets.type, media_assets.uri, media_assets.mime_type,
       media_assets.width_px, media_assets.height_px, media_assets.created_at_epoch_millis AS media_created_at_epoch_millis
FROM photo_edit_results
JOIN media_assets ON media_assets.id = photo_edit_results.edited_media_asset_id
WHERE photo_edit_results.draft_id = ?
ORDER BY photo_edit_results.created_at_epoch_millis ASC;

